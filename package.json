{
	"name": "ros-backend",
	"version": "1.0.0",
	"description": "Restaurant Ordering System",
	"main": "src/server.js",
	"scripts": {
		"start": "npm run build:frontend && node src/server.js",
		"dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
		"dev:backend": "nodemon src/server.js",
		"dev:frontend": "cd src/frontend && npm run dev",
		"build:frontend": "cd src/frontend && npm run build",
		"build": "npm run build:frontend",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"test": "jest --config jest.config.json --runInBand",
		"test:unit": "jest tests/unit/ --config jest.config.json",
		"test:system": "jest tests/system/ --config jest.config.json --runInBand"
	},
	"dependencies": {
		"@prisma/client": "^6.19.3",
		"bcrypt": "^6.0.0",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"helmet": "^8.2.0",
		"jsonwebtoken": "^9.0.3",
		"pdfkit": "^0.18.0",
		"socket.io": "^4.8.3"
	},
	"devDependencies": {
		"concurrently": "^10.0.3",
		"nodemon": "^3.1.14",
		"prisma": "^6.19.3"
	}
}
