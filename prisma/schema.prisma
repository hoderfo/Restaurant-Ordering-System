datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Users with roles
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  auditLogs             AuditLog[]
  voids                 OrderItem[]   @relation("VoidedBy")
  bills                 Bill[]        @relation("ClosedBy")
  reservations          Reservation[] @relation("CreatedBy")
  reservationsCancelled Reservation[] @relation("CancelledBy")
  voidLogs              VoidLog[]

  @@map("users")
}

enum Role {
  admin
  management
  floor
  kitchen
}

// Restaurant tables
model Table {
  id        Int         @id @default(autoincrement())
  label     String      @unique
  capacity  Int
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now())

  reservations Reservation[]
  orders       Order[]

  @@map("tables")
}

enum TableStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  CLEANING
}

// Reservations
model Reservation {
  id            Int               @id @default(autoincrement())
  tableId       Int
  table         Table             @relation(fields: [tableId], references: [id])
  customerName  String
  phone         String
  partySize     Int
  date          DateTime
  startTime     DateTime
  duration      Int               @default(90)
  notes         String?
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  createdById   Int
  createdBy     User              @relation("CreatedBy", fields: [createdById], references: [id])
  cancelledAt   DateTime?
  cancelledById Int?
  cancelledBy   User?             @relation("CancelledBy", fields: [cancelledById], references: [id])

  orders Order[]

  @@map("reservations")
}

enum ReservationStatus {
  PENDING
  SEATED
  CANCELLED
  NO_SHOW
}

// Orders
model Order {
  id            Int          @id @default(autoincrement())
  tableId       Int
  table         Table        @relation(fields: [tableId], references: [id])
  reservationId Int?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
  status        OrderStatus  @default(ACTIVE)
  createdAt     DateTime     @default(now())
  lockedAt      DateTime?

  items OrderItem[]
  bill  Bill?

  @@map("orders")
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  BILLED
}

// Menu items
model MenuItem {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  price       Decimal        @db.Decimal(10, 2)
  category    MenuCategory
  status      MenuItemStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())

  orderItems OrderItem[]

  @@map("menu_items")
}

enum MenuCategory {
  STARTER
  MAIN
  DESSERT
  BEVERAGE
}

enum MenuItemStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

// Order items
model OrderItem {
  id         Int             @id @default(autoincrement())
  orderId    Int
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId Int
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id])
  quantity   Int             @default(1)
  unitPrice  Decimal         @db.Decimal(10, 2)
  note       String?
  status     OrderItemStatus @default(PENDING)
  voidedAt   DateTime?
  voidedById Int?
  voidedBy   User?           @relation("VoidedBy", fields: [voidedById], references: [id])
  createdAt  DateTime        @default(now())

  voidLog VoidLog?

  @@map("order_items")
}

enum OrderItemStatus {
  PENDING
  IN_PREPARATION
  READY
  SERVED
}

// Bills
model Bill {
  id             Int            @id @default(autoincrement())
  orderId        Int            @unique
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  subtotal       Decimal        @db.Decimal(10, 2)
  taxRate        Decimal        @db.Decimal(5, 2)
  taxAmount      Decimal        @db.Decimal(10, 2)
  discountType   DiscountType?
  discountValue  Decimal?       @db.Decimal(10, 2)
  discountAmount Decimal?       @db.Decimal(10, 2)
  discountReason String?
  total          Decimal        @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  closedAt       DateTime?
  closedById     Int?
  closedBy       User?          @relation("ClosedBy", fields: [closedById], references: [id])
  createdAt      DateTime       @default(now())

  @@map("bills")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum PaymentMethod {
  CASH
  CARD
  EWALLET
}

// Void log
model VoidLog {
  id          Int       @id @default(autoincrement())
  orderItemId Int       @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  reason      String
  voidedAt    DateTime  @default(now())
  voidedById  Int
  voidedBy    User      @relation(fields: [voidedById], references: [id])

  @@map("void_log")
}

// Audit log
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  success   Boolean
  ipAddress String?
  details   Json?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
  @@map("audit_log")
}
